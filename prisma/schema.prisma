generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id            String        @id @default(cuid())
  email         String        @unique
  firstName     String?
  lastName      String?
  phone         String?
  districtName  String?
  districtType  String?
  title         String?
  zip           String?
  status        ContactStatus @default(SUBSCRIBED)
  source        String?       @default("import")
  mailchimpLeid String?       @unique
  tags          ContactTag[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum ContactStatus {
  SUBSCRIBED
  UNSUBSCRIBED
  CLEANED
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  contacts ContactTag[]
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formType  FormType
  data      Json
  email     String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum FormType {
  CONTACT
  BOOKING
}

model DigestOpen {
  id        String   @id @default(cuid())
  email     String
  digestId  String
  openedAt  DateTime @default(now())

  @@index([email])
  @@index([digestId])
}

model DigestClick {
  id        String   @id @default(cuid())
  email     String
  digestId  String
  url       String
  clickedAt DateTime @default(now())

  @@index([email])
  @@index([digestId])
}

// ── Newsletter Digest Workflow ──────────────────────────────────────

enum DigestStatus {
  PENDING_REVIEW
  APPROVED
  SENDING_BATCH_1
  SENT_BATCH_1
  SENDING_BATCH_2
  SENT_COMPLETE
}

model Digest {
  id          String       @id @default(cuid())
  weekOf      DateTime
  status      DigestStatus @default(PENDING_REVIEW)
  subject     String?
  htmlContent String?      @db.Text
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  candidates DigestCandidate[]
  sends      DigestSend[]
}

model DigestCandidate {
  id        String   @id @default(cuid())
  digestId  String
  position  Int
  title     String
  summary   String   @db.Text
  source    String
  category  String
  link      String
  published DateTime
  isTexas   Boolean  @default(false)
  selected  Boolean  @default(false)
  take      String?  @db.Text

  digest Digest @relation(fields: [digestId], references: [id], onDelete: Cascade)

  @@unique([digestId, position])
  @@index([digestId])
}

model DigestSend {
  id        String   @id @default(cuid())
  digestId  String
  email     String
  sentAt    DateTime @default(now())
  batch     Int

  digest Digest @relation(fields: [digestId], references: [id], onDelete: Cascade)

  @@unique([digestId, email])
  @@index([digestId])
  @@index([email])
}

// ── Digest Internal Tables (migrated from SQLite) ─────────────────

model SatireHeadline {
  id         String    @id @default(cuid())
  headline   String    @unique
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  timesUsed  Int       @default(0)
  active     Boolean   @default(true)
}

model DigestHistory {
  id               String        @id @default(cuid())
  sentAt           DateTime      @default(now())
  recipients       String?       @db.Text
  storyCount       Int?
  satireHeadlineId String?
  stories          DigestStory[]
  digestSendLogs   DigestSendLog[]
}

model DigestStory {
  id        String  @id @default(cuid())
  digestId  String
  position  Int?
  title     String? @db.Text
  summary   String? @db.Text
  source    String?
  category  String?
  link      String? @db.Text
  take      String? @db.Text
  published String?
  isTexas   Boolean @default(false)
  isSatire  Boolean @default(false)
  bullets   String? @db.Text
  synopsis  String? @db.Text
  highlights String? @db.Text
  relevance String? @db.Text

  digest DigestHistory @relation(fields: [digestId], references: [id], onDelete: Cascade)

  @@index([digestId])
}

model CandidateStory {
  id        String  @id @default(cuid())
  batchDate String
  position  Int
  title     String? @db.Text
  summary   String? @db.Text
  source    String?
  category  String?
  link      String? @db.Text
  published String?
  isTexas   Boolean @default(false)
  selected  Boolean @default(false)
  manual    Boolean @default(false)

  @@index([batchDate])
}

model DigestSendLog {
  id       String   @id @default(cuid())
  digestId String
  email    String
  sentAt   DateTime @default(now())

  digest DigestHistory @relation(fields: [digestId], references: [id], onDelete: Cascade)

  @@unique([digestId, email])
  @@index([digestId])
}

// ── SES Email Infrastructure ──────────────────────────────────────

model Unsubscription {
  id        String   @id @default(cuid())
  email     String
  list      String
  createdAt DateTime @default(now())

  @@unique([email, list])
  @@index([email])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  subject     String
  htmlBody    String   @db.Text
  senderAlias String   @default("info")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClientEmail {
  id           String            @id @default(cuid())
  subject      String
  htmlBody     String            @db.Text
  plainBody    String?           @db.Text
  senderAlias  String            @default("info")
  list         String            @default("product-updates")
  templateId   String?
  status       ClientEmailStatus @default(DRAFT)
  targetTags   String[]
  sentCount    Int               @default(0)
  failCount    Int               @default(0)
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  sends ClientEmailSend[]
}

enum ClientEmailStatus {
  DRAFT
  SENDING
  SENT
  FAILED
}

model ClientEmailSend {
  id            String   @id @default(cuid())
  clientEmailId String
  email         String
  sentAt        DateTime @default(now())

  clientEmail ClientEmail @relation(fields: [clientEmailId], references: [id], onDelete: Cascade)

  @@unique([clientEmailId, email])
  @@index([clientEmailId])
  @@index([email])
}

model ClientEmailOpen {
  id            String   @id @default(cuid())
  email         String
  clientEmailId String
  openedAt      DateTime @default(now())

  @@index([email])
  @@index([clientEmailId])
}

model ClientEmailClick {
  id            String   @id @default(cuid())
  email         String
  clientEmailId String
  url           String
  clickedAt     DateTime @default(now())

  @@index([email])
  @@index([clientEmailId])
}

model InboundEmail {
  id          String   @id @default(cuid())
  fromEmail   String
  fromName    String?
  toEmail     String
  subject     String
  bodyText    String?  @db.Text
  bodyHtml    String?  @db.Text
  category    String?
  status      String   @default("new")
  actions     String?  @db.Text
  receivedAt  DateTime @default(now())
  processedAt DateTime?

  @@index([fromEmail])
  @@index([toEmail])
  @@index([category])
  @@index([status])
}
